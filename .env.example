# Required: GitHub username whose repository languages are visualized
GITHUB_USERNAME=

# Optional: increases rate limits and allows access to private repos
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Run:
#   cp .env.example .env
#   # edit .env with your username (and optional token)
#   cargo run
#
# Test:
#   curl http://localhost:3000/languages --output languages.svg
